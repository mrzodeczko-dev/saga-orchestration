# ============================================================================
# RABBITMQ
# ============================================================================
RABBITMQ_VERSION=4.1.1-management
RABBITMQ_ERLANG_COOKIE=changeMe
RABBITMQ_ADMIN_USER=admin
RABBITMQ_ADMIN_PASS=changeMe

# Polaczenie aplikacji z klastrem RabbitMQ
SPRING_RABBITMQ_ADDRESSES=amqp://rabbitmq1:5672,amqp://rabbitmq2:5672,amqp://rabbitmq3:5672
SPRING_RABBITMQ_USERNAME=admin
SPRING_RABBITMQ_PASSWORD=changeMe
SPRING_RABBITMQ_VIRTUAL_HOST=/

# ============================================================================
# BOOKING SERVICE
# ============================================================================
BOOKING_SERVICE_PORT=8080
BOOKING_SERVICE_APPLICATION_NAME=booking-service

# MySQL
BOOKING_SERVICE_MYSQL_DB_HOST=booking-mysql
BOOKING_SERVICE_MYSQL_DB_PORT=3307
BOOKING_SERVICE_MYSQL_DB_NAME=booking_db
BOOKING_SERVICE_MYSQL_DB_USER=booking
BOOKING_SERVICE_MYSQL_DB_PASSWORD=changeMe
BOOKING_SERVICE_MYSQL_DB_ROOT_PASSWORD=changeMe
BOOKING_SERVICE_MYSQL_INNODB_BUFFER_POOL_SIZE=128M
BOOKING_SERVICE_MYSQL_MAX_CONNECTIONS=100

# ============================================================================
# FLIGHT SERVICE
# ============================================================================
FLIGHT_SERVICE_PORT=8081
FLIGHT_SERVICE_APPLICATION_NAME=flight-service

# MySQL
FLIGHT_SERVICE_MYSQL_DB_HOST=flight-mysql
FLIGHT_SERVICE_MYSQL_DB_PORT=3308
FLIGHT_SERVICE_MYSQL_DB_NAME=flight_db
FLIGHT_SERVICE_MYSQL_DB_USER=flight
FLIGHT_SERVICE_MYSQL_DB_PASSWORD=changeMe
FLIGHT_SERVICE_MYSQL_DB_ROOT_PASSWORD=changeMe
FLIGHT_SERVICE_MYSQL_INNODB_BUFFER_POOL_SIZE=128M
FLIGHT_SERVICE_MYSQL_MAX_CONNECTIONS=100

# ============================================================================
# HOTEL SERVICE
# ============================================================================
HOTEL_SERVICE_PORT=8082
HOTEL_SERVICE_APPLICATION_NAME=hotel-service

# MySQL
HOTEL_SERVICE_MYSQL_DB_HOST=hotel-mysql
HOTEL_SERVICE_MYSQL_DB_PORT=3309
HOTEL_SERVICE_MYSQL_DB_NAME=hotel_db
HOTEL_SERVICE_MYSQL_DB_USER=hotel
HOTEL_SERVICE_MYSQL_DB_PASSWORD=changeMe
HOTEL_SERVICE_MYSQL_DB_ROOT_PASSWORD=changeMe
HOTEL_SERVICE_MYSQL_INNODB_BUFFER_POOL_SIZE=128M
HOTEL_SERVICE_MYSQL_MAX_CONNECTIONS=100

# ============================================================================
# PAYMENT SERVICE
# ============================================================================
PAYMENT_SERVICE_PORT=8083
PAYMENT_SERVICE_APPLICATION_NAME=payment-service

# MySQL
PAYMENT_SERVICE_MYSQL_DB_HOST=payment-mysql
PAYMENT_SERVICE_MYSQL_DB_PORT=3310
PAYMENT_SERVICE_MYSQL_DB_NAME=payment_db
PAYMENT_SERVICE_MYSQL_DB_USER=payment
PAYMENT_SERVICE_MYSQL_DB_PASSWORD=changeMe
PAYMENT_SERVICE_MYSQL_DB_ROOT_PASSWORD=changeMe
PAYMENT_SERVICE_MYSQL_INNODB_BUFFER_POOL_SIZE=128M
PAYMENT_SERVICE_MYSQL_MAX_CONNECTIONS=100

# ============================================================================
# SECURITY PLATFORM
# ============================================================================

# --- Shared secrets (must match across all security services) ---
# Generate: openssl rand -base64 64 | tr -d '\n'
SECURITY_JWT_SECRET=changeMe
# Generate: openssl rand -base64 32 | tr -d '\n'
SECURITY_INTERNAL_SECRET=changeMe

# --- API Gateway ---
API_GATEWAY_SERVICE_PORT=8085
API_GATEWAY_RATE_LIMIT_ENABLED=true
API_GATEWAY_RATE_LIMIT_RPS=20
API_GATEWAY_RATE_LIMIT_BURST=40
SPRINGDOC_ENABLED=false

# --- Redis (Auth + Gateway rate limiting) ---
AUTH_REDIS_HOST=auth-redis
AUTH_REDIS_PORT=6379
AUTH_REDIS_PASSWORD=changeMe

# --- Auth Service ---
AUTH_JWT_ACCESS_TOKEN_EXPIRATION_MS=300000
AUTH_JWT_REFRESH_TOKEN_EXPIRATION_MS=3000000

# --- User Service ---
USER_SERVICE_MYSQL_DB_HOST=user-mysql
USER_SERVICE_MYSQL_DB_NAME=users_db
USER_SERVICE_MYSQL_DB_USER=user
USER_SERVICE_MYSQL_DB_PASSWORD=changeMe
USER_SERVICE_MYSQL_DB_ROOT_PASSWORD=changeMe
USER_SERVICE_MYSQL_INNODB_BUFFER_POOL_SIZE=256M
USER_SERVICE_MYSQL_MAX_CONNECTIONS=200

USER_SERVICE_MAIL_HOST=smtp.gmail.com
USER_SERVICE_MAIL_USERNAME=changeMe
USER_SERVICE_MAIL_PASSWORD=changeMe
USER_SERVICE_MAIL_PORT=587
USER_SERVICE_MFA_ISSUER=SagaBookingSystem
